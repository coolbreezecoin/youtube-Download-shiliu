{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "拾流下载器",
  "version": "0.1.1",
  "identifier": "com.coolbreeze.ytdownloader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "拾流下载器",
        "width": 1480,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/ffmpeg-libs/": "ffmpeg-libs/",
      "resources/ffmpeg-libs-x86_64-apple-darwin/": "ffmpeg-libs-x86_64-apple-darwin/",
      "resources/python-runtime-aarch64-apple-darwin/": "python-runtime-aarch64-apple-darwin/",
      "resources/python-runtime-x86_64-apple-darwin/": "python-runtime-x86_64-apple-darwin/"
    },
    "externalBin": [
      "binaries/yt-dlp",
      "binaries/ffmpeg",
      "binaries/ffprobe",
      "binaries/deno"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
